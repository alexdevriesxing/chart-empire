{
  "name": "chart-empire",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Chart Empire: The Music Label Manager — a Cloudflare-ready Phaser 4 management game.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "cf:dev": "wrangler pages dev dist",
    "cf:deploy": "wrangler pages deploy dist",
    "db:migrate:local": "wrangler d1 migrations apply chart-empire-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply chart-empire-db --remote"
  },
  "dependencies": {
    "phaser": "^4.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260620.0",
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^7.2.7",
    "vitest": "^4.0.16",
    "wrangler": "^4.54.0"
  }
}
